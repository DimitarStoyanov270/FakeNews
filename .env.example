# Copy this file to .env.local and fill in your values.
# On Vercel/Netlify, set these as Environment Variables in the dashboard instead.

# Admin login — single account. Protects /admin, /admin/ads and the publish/ads
# APIs. The login form is only reachable at the secret URL /adminlogin.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET=replace-with-a-long-random-string

# Submissions email (optional but recommended). Free key from https://web3forms.com
# Submissions from the public "Submit a Fake Story" form are emailed to the
# address you registered with Web3Forms. This key is safe to expose publicly.
NEXT_PUBLIC_WEB3FORMS_KEY=
